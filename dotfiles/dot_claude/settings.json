{
  "permissions": {
    "allow": [
      "Read(//nix/**)",
      "Read(~/.claude/instructions/**)",
      "Bash(grep:*)",
      "Bash(ls:*)"
    ],
    "deny": [
      "Read(//etc/shadow)",
      "Read(//**/.env)",
      "Read(//**/.env.*)",
      "Read(//**/secrets/**)",
      "Read(//**/.secrets/**)",
      "Read(//**/*.priv.*)",
      "Edit(//etc/passwd)",
      "Edit(//etc/shadow)",
      "Edit(//**/.env)",
      "Edit(//**/.env.*)",
      "Edit(//**/secrets/**)",
      "Edit(//**/.secrets/**)",
      "Edit(//**/*.priv.*)",
      "Write(//etc/passwd)",
      "Write(//etc/shadow)",
      "Write(//**/.env)",
      "Write(//**/.env.*)",
      "Write(//**/secrets/**)",
      "Write(//**/.secrets/**)",
      "Write(//**/*.priv.*)"
    ],
    "defaultMode": "default"
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "claude-md-management@claude-plugins-official": true
  },
  "sandbox": {
    "filesystem": {
      "denyWrite": [
        "~/.secrets",
        "~/.config",
        "~.ssh/"
      ],
      "denyRead": [
        "/etc/shadow",
        "~/.secrets",
        "~/.config",
        "~/.ssh/"
      ]
    }
  },
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [
      "Thinking"
    ]
  }
}
