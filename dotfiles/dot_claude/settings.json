{
  "permissions": {
    "allow": ["Read(//nix/**)", "Bash(grep:*)", "Bash(ls:*)"],
    "deny": [
      "Read(//etc/passwd)",
      "Read(//etc/shadow)",
      "Read(//**/.env)",
      "Read(//**/.env.*)",
      "Read(//**/secrets/**)",
      "Read(//**/.secrets/**)",
      "Read(//**/priv.*)",
      "Bash(cd:*)",
      "Bash(git* -C:*)"
    ],
    "defaultMode": "default"
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": ["Thinking"]
  }
}
